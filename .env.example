APP_NAME=TalkLikeHuman

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.8

OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

SKILL_SOURCE=https://raw.githubusercontent.com/blader/humanizer/refs/heads/main/SKILL.md
SKILL_CACHE_TTL=600

# Demo mode — set to true to enable per-IP daily credit limit
DEMO=false
DEMO_CREDITS_PER_DAY=5

# Upstash Redis — required when DEMO=true
UPSTASH_REDIS_REST_URL=your_upstash_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Used for SEO and Meta tags
NEXT_PUBLIC_APP_URL=https://humanize.afifzafri.com

# API Protection — Cloudflare Turnstile (https://dash.cloudflare.com/?to=/:account/turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Session signing secret — generate with: openssl rand -base64 32
SESSION_SECRET=your_random_secret_here
